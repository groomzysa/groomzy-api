{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es6",
    "noImplicitAny": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": "./src",
    "rootDir": "./",
    "paths": {
      "node_modules/*": ["node_modules/*"],
      "utils/*":["./src/utils/*"]
    }
  },
  "include": [
    "./node_modules",
    "./src"
  ]
}
